# BuiltLocal live SMS test environment
# Add these values in Vercel Project Settings > Environment Variables.
# Do not commit real secret values.

SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=
# Optional later:
# TWILIO_MESSAGING_SERVICE_SID=

PUBLIC_SITE_URL=https://scottvan08.github.io/localtrades-south-dundas
PUBLIC_API_URL=https://your-vercel-project.vercel.app

# Keep false for first trial-account setup. Switch to true after webhook URLs are final.
TWILIO_VALIDATE_WEBHOOKS=false
ROUTING_SWEEP_SECRET=
ADMIN_REVIEW_SECRET=

# Optional later. Leave blank for first SMS test so the fallback Job Snapshot is used.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini
